{
  "basePath": "/",
  "definitions": {
    "Task": {
      "properties": {
        "description": {
          "description": "Task description",
          "type": "string"
        },
        "id": {
          "description": "Task unique identifier",
          "type": "integer"
        },
        "status": {
          "description": "Task status (todo, in_progress, done)",
          "type": "string"
        },
        "title": {
          "description": "Task title",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "host": "localhost:5162",
  "info": {
    "description": "A simple Kanban board API for task management",
    "title": "Kanban Board API",
    "version": "1.0"
  },
  "paths": {
    "/": {
      "get": {
        "description": "Returns a list of all tasks",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "schema": {
              "properties": {
                "tasks": {
                  "items": {
                    "$ref": "#/definitions/Task"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Get all tasks"
      }
    },
    "/add": {
      "post": {
        "consumes": [
          "application/x-www-form-urlencoded"
        ],
        "description": "Creates a new task with the given title and description",
        "parameters": [
          {
            "description": "Task title",
            "in": "formData",
            "name": "title",
            "required": true,
            "type": "string"
          },
          {
            "description": "Task description",
            "in": "formData",
            "name": "description",
            "required": true,
            "type": "string"
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "201": {
            "description": "Task created successfully",
            "schema": {
              "properties": {
                "task": {
                  "$ref": "#/definitions/Task"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Add a new task"
      }
    },
    "/delete": {
      "post": {
        "consumes": [
          "application/x-www-form-urlencoded"
        ],
        "description": "Removes a task from the database",
        "parameters": [
          {
            "description": "Task ID to delete",
            "in": "formData",
            "name": "task_id",
            "required": true,
            "type": "integer"
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "Task deleted successfully",
            "schema": {
              "properties": {
                "ok": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Delete a task"
      }
    },
    "/move": {
      "post": {
        "consumes": [
          "application/x-www-form-urlencoded"
        ],
        "description": "Updates the status of an existing task",
        "parameters": [
          {
            "description": "Task ID to move",
            "in": "formData",
            "name": "task_id",
            "required": true,
            "type": "integer"
          },
          {
            "description": "New status (todo, in_progress, done)",
            "in": "formData",
            "name": "status",
            "required": true,
            "type": "string"
          }
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "Task moved successfully",
            "schema": {
              "properties": {
                "task": {
                  "$ref": "#/definitions/Task"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Move a task to a different status"
      }
    }
  },
  "schemes": [
    "http"
  ],
  "swagger": "2.0"
}
